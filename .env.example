# ─────────────────── LLM 配置 ───────────────────
# 主模型 (DeepSeek) —— 用于复杂任务：任务规划、反思修正、导购推荐等
# 当主模型不可用时，系统自动降级到备用模型（SmartModelRouter 智能路由）
LLM_API_KEY=sk-your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 备用模型 (OpenAI) —— 用于轻量任务：闲聊、简单改写等，同时作为主模型的 fallback
# 任务复杂度分三级：
#   LIGHT  → 优先用备用模型（省成本）
#   MEDIUM → 用主模型
#   HEAVY  → 用主模型 + 额外超时保护
FALLBACK_LLM_API_KEY=sk-your-openai-api-key
FALLBACK_LLM_BASE_URL=https://api.openai.com/v1
FALLBACK_LLM_MODEL=gpt-4o-mini

# ─────────────────── Embedding 配置 ───────────────────
# Embedding 模型的输出维度必须与 Milvus 集合配置一致：
#   text-embedding-3-large  → 3072 维（默认，与 Milvus user_memory 集合匹配）
#   text-embedding-3-small  → 1536 维
#   text-embedding-ada-002  → 1536 维
# 如更换模型，需同步修改 app/tools/memory.py 中的 _MEMORY_VECTOR_DIM
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=sk-your-embedding-api-key
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-large

# ─────────────────── LangSmith 配置 ───────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-your-langsmith-api-key
LANGCHAIN_PROJECT=rec-agent

# ─────────────────── MySQL 配置 ───────────────────
MYSQL_HOST=127.0.0.1
# 注意：如果使用 Docker Compose 部署 MySQL，映射端口可能不是默认 3306
# docker-compose.yml 中配置为 23306:3306 时，这里应填 23306
MYSQL_PORT=23306
MYSQL_USER=root
# docker-compose 中 MySQL 容器也通过此变量读取 root 密码
MYSQL_PASSWORD=changeme
MYSQL_DATABASE=rec_agent

# ─────────────────── Elasticsearch 配置 ───────────────────
ES_HOST=http://127.0.0.1:9200
ES_INDEX_NAME=product_index
ES_USERNAME=
# docker-compose 中 ES 容器也通过此变量读取 elastic 密码
ES_PASSWORD=changeme

# ─────────────────── Milvus 配置 ───────────────────
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION=knowledge_base

# ─────────────────── Redis 配置 ───────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ─────────────────── Langfuse 配置 ───────────────────
# 启用后需同时配置 PUBLIC_KEY 和 SECRET_KEY，否则启动时校验会报错
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-your-langfuse-public-key
LANGFUSE_SECRET_KEY=sk-your-langfuse-secret-key
LANGFUSE_HOST=http://localhost:3000
